# DermaScout config — copy to .env and fill in. Everything works without keys
# (prints voice lines, uses template explanations), keys just make it richer.

# ---- Demo failsafe flags (the Tier ladder) ----
# Start everything off (Tier 0/voice+vision only), flip on as hardware comes online.
DERMA_USE_ARM=false          # serial actuator (needs DERMA_SERIAL_PORT)
DERMA_USE_MACRO=false         # macro USB camera (needs DERMA_MACRO_CAM_INDEX)
DERMA_USE_SLAM=false          # RTABMap sweep (experimental; off for the judged demo)
DERMA_USE_VOICE=true
DERMA_USE_CLASSIFIER=true
DERMA_USE_POSE=true

# ---- camera ----
DERMA_CAM_W=640
DERMA_CAM_H=400
DERMA_CAM_FPS=30

# ---- actuator (ESP32) ----
# macOS: ls /dev/tty.usbmodem*   Linux: /dev/ttyUSB0 or /dev/ttyACM0
DERMA_SERIAL_PORT=
DERMA_SERIAL_BAUD=115200

# ---- macro camera ----
DERMA_MACRO_CAM_INDEX=1

# ---- triage ----
DERMA_CLASSIFIER_MODEL=ahishamm/vit-base-HAM-10000-patch-16
DERMA_DEVICE=                 # ""=auto (mps/cuda/cpu), or force "cpu"/"mps"/"cuda"

# ---- VLM explanation (optional) ----
DERMA_VLM_PROVIDER=anthropic  # anthropic | openai | off
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- ElevenLabs voice (optional) ----
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
ELEVENLABS_VOICE_ID=          # blank uses a default voice

# ---- backend ----
DERMA_BACKEND_HOST=127.0.0.1
DERMA_BACKEND_PORT=8000

# ---- optional 4090 inference offload ----
DERMA_INFERENCE_URL=
